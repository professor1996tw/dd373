{
  "manifest_version": 3,
  "name": "SunWater DD373 自動進貨系統",
  "version": "2.0",
  "description": "自動爬取 DD373 訂單資料並計算進貨成本，無需手動複製貼上",
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://order.dd373.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SunWater DD373 自動進貨"
  }
}
